{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "camper-calc",
  "title": "Camper Van Cost Tracker",
  "description": "Calculate the real cost of your camper van per day – track expenses, residual value, and yearly breakdown.",
  "icon": "extension-icon.png",
  "author": "wdeu",
  "platforms": ["macOS"],
  "license": "MIT",
  "categories": ["Finance"],
  "keywords": ["camper", "van", "motorhome", "cost", "calculator", "depreciation", "expenses"],
  "commands": [
    {
      "name": "camper-calc",
      "title": "Camper-Calc",
      "description": "Open the cost calculator",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "eslint": "^9.22.0",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
