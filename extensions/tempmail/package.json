{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "tempmail",
  "title": "TempMail",
  "description": "Temporary email mailbox using the mail.gw API",
  "icon": "command-icon.png",
  "author": "Joshlucpoll",
  "categories": [
    "Applications",
    "Communication"
  ],
  "license": "MIT",
  "platforms": [
    "macOS",
    "Windows"
  ],
  "commands": [
    {
      "name": "tempmail",
      "title": "Open Mailbox",
      "description": "Open TempMail inbox to manage and view emails and addresses",
      "mode": "view"
    },
    {
      "name": "reset",
      "title": "Reset TempMail",
      "description": "Resets TempMail to default settings",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.16",
    "@raycast/utils": "^2.2.4",
    "axios": "^1.8.4",
    "moment": "^2.29.4",
    "node-html-markdown": "^1.3.0",
    "unique-names-generator": "^4.7.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "^22",
    "@types/react": "19.0.10",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "minimatch": "^9.0.7"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "ray publish"
  }
}